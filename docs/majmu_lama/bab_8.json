                        "tipe_tampilan": "judul_tengah"
                    },
                    {
                        "urutan": 15,
                        "arabic": "حَمْدًا يُوَافِي نِعَمَهُ وَيُكَافِئُ مَزِيْدَهُ يَا رَبَّنَا لَكَ الْحَمْدُ كَمَا يَنْبَغِي لِجَلَالِ وَجْهِكَ وَعَظِيْمِ سُلْطَانِكَ. سُبْحَانَكَ لَا نُحْصِي ثَنَاءً عَلَيْكَ أَنْتَ كَمَا أَثْنَيْتَ عَلَى نَفْسِكَ.",
                        "tipe_tampilan": "text"
                    },
                    {
                        "urutan": 16,
                        "arabic": "اَللّٰهُمَّ صَلِّ عَلَى سَيِّدِنَا مُحَمَّدٍ صَلَاةً تُوَسِّعُ بِهَا عَلَيْنَا الْأَرْزَاقَ. وَتُحَسِّنُ بِهَا لَنَا الْأَخْلَاقَ. وَعَلَى اٰلِهِ وَصَحْبِهِ وَسَلَّمْ.",
                        "tipe_tampilan": "text"
                    },
                    {
                        "urutan": 17,
                        "arabic": "اَللّٰهُمَّ اِنَّ الضُّحَاءَ ضُحَاؤُكَ وَالْبَهَاءَ بَهَاؤُكَ وَالْجَمَالَ جَمَالُكَ وَالْقُوَّةَ قُوَّتُكَ وَالْقُدْرَةَ قُدْرَتُكَ وَالْعِصْمَةَ عِصْمَتُكَ.",
                        "tipe_tampilan": "text"
                    },
                    {
                        "urutan": 18,
                        "arabic": "اَللّٰهُمَّ إِنْ كَانَ رِزْقُنَا فِي السَّمَاءِ فَأَنْزِلْهُ. فَإِنْ كَانَ فِي الْأَرْضِ فَأَخْرِجْهُ فَإِنْ كَانَ بَعِيْدًا فَقَرِّبْهُ فَإِنْ كَانَ حَرَامًا فَطَهِّرْهُ فَإِنْ كَانَ مُعَسِّرًا فَيَسِّرْهُ فَبَارِكْ لَنَا فِيْهِ.",
                        "tipe_tampilan": "text"
                    },
                    {
                        "urutan": 19,
                        "arabic": "وَارْزُقْنَا مِنْ حَيْثُ نَحْتَسِبُ. وَمِنْ حَيْثُ لَا نَحْتَسِبُ رِزْقًا حَلَالًا طَيِّبًا غَدَقًا سَحًّا مُبَارَكًا. حَتَّى لَا تَكُوْنَ لِأَحَدٍ مِنْ خَلْقِكَ عَلَيْهِ مِنَّةٌ.",
                        "tipe_tampilan": "text"
                    },
                    {
                        "urutan": 20,
                        "arabic": "بِحَقِّ ضُحَائِكَ وَبَهَائِكَ وَجَمَالِكَ وَقُوَّتِكَ وَقُدْرَتِكَ. اٰتِنَا مَا اٰتَيْتَ عِبَادَكَ الصَّالِحِيْنَ.",
                        "tipe_tampilan": "text"
                    },
                    {
                        "urutan": 21,
                        "arabic": "اَللّٰهُمَّ اغْفِرْ لِي ذُنُوْبِي وَلِوَالِدَيَّ وَارْحَمْهُمَا كَمَا رَبَّيَانِي صَغِيْرًا. رَبَّنَا اٰتِنَا فِي الدُّنْيَا حَسَنَةً وَفِي الْاٰخِرَةِ حَسَنَةً وَقِنَا عَذَابَ النَّارِ.",
                        "tipe_tampilan": "text"
                    },
                    {
                        "urutan": 22,
                        "arabic": "وَصَلَّى اللّٰهُ عَلَى سَيِّدِنَا مُحَمَّدٍ النَّبِيِّ الْأُمِّيِّ وَعَلَى اٰلِهِ وَصَحْبِهِ وَسَلَّمَ.",
                        "tipe_tampilan": "text"
                    },
                    {
                        "urutan": 23,
                        "arabic": "سُبْحَانَ رَبِّكَ رَبِّ الْعِزَّةِ عَمَّا يَصِفُوْنَ وَسَلَامٌ عَلَى الْمُرْسَلِيْنَ. وَالْحَمْدُ لِلّٰهِ رَبِّ الْعَالَمِيْنَ. (Al-Fatihah)",
                        "tipe_tampilan": "text"
                    }
